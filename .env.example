# === LLM ===
GROQ_API_KEY=your_groq_api_key_here
# OR Azure OpenAI (uncomment to use GPT instead of Groq)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# === Embeddings (Azure OpenAI) ===
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_API_VERSION=2024-02-01
EMBEDDING_DEPLOYMENT=text-embedding-3-large

# === Vector DB ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                         # leave blank for local dev

# === Azure AD (Auth) ===
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-client-id
AZURE_CLIENT_SECRET=your-client-secret  # for backend app registration

# === LangSmith (Observability) ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=rag-enterprise-chatbot

# === Azure Monitor ===
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# === App Settings ===
APP_ENV=development                      # development | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173       # frontend dev server
JWT_ALGORITHM=RS256
